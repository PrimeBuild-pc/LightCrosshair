<Window x:Class="LightCrosshair.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LightCrosshair Settings" Height="600" Width="1320"
        WindowStartupLocation="Manual"
        ResizeMode="CanResize"
        Topmost="False"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <!-- Base styles using dynamic theme resources provided by code-behind -->
        <Style TargetType="TabControl">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
        </Style>

        <!-- TabItem: custom template to avoid white selected header in dark theme -->
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        </Style>
        <Style TargetType="StackPanel">
            <Setter Property="Background" Value="{DynamicResource PanelBg}"/>
        </Style>

        <!-- Flat button style -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <!-- ComboBox with dark popup -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4"/>
                            <Grid>
                                <ToggleButton Grid.Column="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press" Background="Transparent" BorderBrush="{x:Null}" Cursor="Hand"/>
                                <ContentPresenter Margin="8,2,24,2" VerticalAlignment="Center" HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                            </Grid>
                            <Popup Name="PART_Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="{DynamicResource ControlBg}" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1" CornerRadius="4">
                                    <ScrollViewer>
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
            <Setter Property="Background" Value="{DynamicResource ControlBg}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
        </Style>

        <!-- Modern slider -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="0,6">
                            <Border Background="{DynamicResource ControlBg}" CornerRadius="2" Height="4" VerticalAlignment="Center"/>
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Height="4" Background="{DynamicResource AccentBrush}" Command="Slider.DecreaseLarge"/>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Height="4" Background="Transparent" Command="Slider.IncreaseLarge"/>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12" Height="12" Background="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextFg}"/>
        </Style>
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Grid x:Name="RootPanel" Background="{DynamicResource PanelBg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top bar: theme toggle fixed at top-left -->
        <StackPanel Orientation="Horizontal" Margin="8" Grid.Row="0">
            <Button x:Name="ThemeToggle" Width="40" Height="28" ToolTip="Toggle Theme" Foreground="{DynamicResource AccentBrush}">
                <TextBlock x:Name="ThemeGlyph" Text="🌙" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
        </StackPanel>

        <!-- Main content with left tabs -->
                <TabControl TabStripPlacement="Left" Margin="8" Grid.Row="1">
            <!-- Crosshair Builder Tab -->
            <TabItem x:Name="BuilderTab" Header="Crosshair Builder">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Basic Options" FontWeight="Bold" Margin="0,0,0,6"/>
                        <CheckBox x:Name="EnableCustomCrosshairCheckbox" Content="Enable Custom Crosshair" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Shape:" Width="120" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ShapeCombo" Width="260">
                                <ComboBoxItem Content="Dot"/>
                                <ComboBoxItem Content="Cross"/>
                                <ComboBoxItem Content="Circle"/>
                            </ComboBox>
                        </StackPanel>

                        <TextBlock Text="Dimensions" FontWeight="Bold" Margin="0,12,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Size:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="SizeSlider" Minimum="2" Maximum="100" Width="260"/>
                            <TextBlock x:Name="SizeValue" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Thickness:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="ThicknessSlider" Minimum="1" Maximum="20" Width="260"/>
                            <TextBlock x:Name="ThicknessValue" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Outline:" Width="120" VerticalAlignment="Center"/>
                            <CheckBox x:Name="OutlineCheckbox" Content="Use Secondary/Edge Color" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Gap:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="GapSlider" Minimum="0" Maximum="50" Width="260"/>
                            <TextBlock x:Name="GapValue" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="Colors" FontWeight="Bold" Margin="0,12,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button x:Name="OuterColorBtn" Content="Main Color" Width="140"/>
                            <Button x:Name="InnerShapeColorBtn" Content="Secondary/Edge Color" Width="190" Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <TextBlock Text="Position &amp; Tweaks" FontWeight="Bold" Margin="0,12,0,6"/>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                            <Button x:Name="NudgeLeft" Content="←" Width="40" ToolTip="Move left 1px"/>
                            <Button x:Name="NudgeUp" Content="↑" Width="40" ToolTip="Move up 1px"/>
                            <Button x:Name="NudgeDown" Content="↓" Width="40" ToolTip="Move down 1px"/>
                            <Button x:Name="NudgeRight" Content="→" Width="40" ToolTip="Move right 1px"/>
                            <Button x:Name="ResetCenterBtn" Content="Reset Center" Width="100" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="CurrentPositionText" Text="Current Position: X=0, Y=0" Opacity="0.7"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem x:Name="HotkeysTab" Header="Hotkeys">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Global Hotkeys" FontWeight="Bold" Margin="0,0,0,12"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Toggle Crosshair:" Width="140" VerticalAlignment="Center"/>
                            <CheckBox x:Name="HkAlt1" Content="Alt" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="HkCtrl1" Content="Ctrl" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="HkShift1" Content="Shift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="HkKey1Combo" Width="100"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Cycle Profiles:" Width="140" VerticalAlignment="Center"/>
                            <CheckBox x:Name="HkAlt2" Content="Alt" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="HkCtrl2" Content="Ctrl" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <CheckBox x:Name="HkShift2" Content="Shift" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <ComboBox x:Name="HkKey2Combo" Width="100"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Gamma & Vibrance Tab -->
            <TabItem x:Name="DisplayTab" Header="Display Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Display Adjustments" FontWeight="Bold" Margin="0,0,0,12"/>

                        <Border Background="{DynamicResource ControlBg}" BorderBrush="{DynamicResource ControlBorder}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                            <StackPanel>
                                <TextBlock Text="Color Backend" FontWeight="Bold"/>
                                <TextBlock x:Name="ColorBackendText" Text="Detecting..." Margin="0,4,0,0"/>
                                <TextBlock x:Name="ColorBackendDetailsText" Text="-" Opacity="0.75" TextWrapping="Wrap" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Border>

                        <CheckBox x:Name="EnableGammaCheckbox" Content="Enable Gamma/Contrast/Brightness/Vibrance Override" Margin="0,0,0,12"/>

                        <TextBlock Text="Apply Settings To" FontWeight="Bold" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="Target Process:" Width="120" VerticalAlignment="Center"/>
                            <TextBox x:Name="TargetProcessTextBox" Width="180" Margin="0,0,8,0" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}" ToolTip="Leave empty to apply globally. Example: valorant.exe"/>
                            <ComboBox x:Name="ProcessPickerComboBox" Width="180" Margin="0,0,8,0" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}" ToolTip="Select from currently running processes"/>
                            <Button x:Name="RefreshProcessListBtn" Content="Refresh List" Width="100" Margin="0,0,8,0" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <Button x:Name="BrowseProcessExeBtn" Content="Browse .exe" Width="110" Margin="0,0,8,0" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <Button x:Name="ClearTargetProcessBtn" Content="Clear" Width="80" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                        </StackPanel>
                        <TextBlock Text="Manual mode: pick a running process, browse an .exe, or type one. Leave empty to apply globally." Opacity="0.75" TextWrapping="Wrap" Margin="0,0,0,8"/>
                        <!-- Note: Software fallback was removed from the codebase. -->
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Gamma:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="GammaSlider" Minimum="50" Maximum="150" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <TextBlock x:Name="GammaValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Contrast:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="ContrastSlider" Minimum="50" Maximum="150" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <TextBlock x:Name="ContrastValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Brightness:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="BrightnessSlider" Minimum="50" Maximum="150" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <TextBlock x:Name="BrightnessValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Vibrance:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="VibranceSlider" Minimum="0" Maximum="100" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableGammaCheckbox}"/>
                            <TextBlock x:Name="VibranceValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Note: Hardware path is preferred. If disabled, software fallback will not be used when hardware apply fails." Opacity="0.7" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- FPS Overlay Tab -->
            <TabItem x:Name="FpsTab" Header="FPS &amp; Performance">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <TextBlock Text="Performance Overlay" FontWeight="Bold" Margin="0,0,0,12"/>
                        <CheckBox x:Name="EnableFpsCheckbox" Content="Enable FPS Overlay" Margin="0,0,0,12"/>
                        
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="Position X:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="FpsXSlider" Minimum="0" Maximum="3840" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableFpsCheckbox}"/>
                            <TextBlock x:Name="FpsXValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <TextBlock Text="Position Y:" Width="120" VerticalAlignment="Center"/>
                            <Slider x:Name="FpsYSlider" Minimum="0" Maximum="2160" Width="260" IsEnabled="{Binding IsChecked, ElementName=EnableFpsCheckbox}"/>
                            <TextBlock x:Name="FpsYValueText" Width="50" TextAlignment="Right" Margin="8,0,0,0"/>
                        </StackPanel>
                        
                        <CheckBox x:Name="ShowFrametimeCheckbox" Content="Show Frametime Graph" Margin="0,0,0,6" IsEnabled="{Binding IsChecked, ElementName=EnableFpsCheckbox}"/>
                        <CheckBox x:Name="Show1PercentCheckbox" Content="Show 1% Lows" Margin="0,0,0,6" IsEnabled="{Binding IsChecked, ElementName=EnableFpsCheckbox}"/>
                        <CheckBox x:Name="ShowGenFramesCheckbox" Content="Show Generated Frames (when detected)" Margin="0,0,0,12" IsEnabled="{Binding IsChecked, ElementName=EnableFpsCheckbox}"/>

                        <TextBlock Text="Colors" FontWeight="Bold" Margin="0,12,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <Button x:Name="FpsTextColorBtn" Content="Text Color" Width="140"/>
                            <Button x:Name="FpsBgColorBtn" Content="Background Color" Width="140" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

<!-- Profiles Tab -->
            <TabItem x:Name="ProfilesTab" Header="Profiles">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,8">
                        <Button x:Name="SaveCurrentProfileBtn" Content="Save Current to Selected" Width="220"/>
                    </StackPanel>
                    <ListBox x:Name="ProfilesList" Grid.Row="1" BorderBrush="{DynamicResource ControlBorder}" Background="{DynamicResource PanelBg}" Foreground="{DynamicResource TextFg}"/>
                    <TextBlock Grid.Row="2" Text="Up to 10 profiles. Select a slot to Save/Load/Rename/Delete." Foreground="{DynamicResource TextFg}" Opacity="0.7" Margin="0,8,0,0"/>
                </Grid>
            </TabItem>


            <!-- About Tab -->
            <TabItem x:Name="AboutTab" Header="About">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16" >
                        <TextBlock Text="LightCrosshair" FontWeight="Bold" FontSize="16"/>
                        <TextBlock x:Name="VersionText" Text="Version: -" Margin="0,8,0,0"/>
                        <TextBlock Text="Author: PrimeBuild" Margin="0,8,0,0"/>
                        <TextBlock Margin="0,8,0,0">
                            <Run Text="Website: "/>
                            <Hyperlink Foreground="{DynamicResource AccentBrush}" NavigateUri="https://primebuild.website/" RequestNavigate="OnHyperlinkNavigate">https://primebuild.website/</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,4,0,0">
                            <Run Text="GitHub: "/>
                            <Hyperlink Foreground="{DynamicResource AccentBrush}" NavigateUri="https://github.com/PrimeBuild-pc/LightCrosshair" RequestNavigate="OnHyperlinkNavigate">https://github.com/PrimeBuild-pc/LightCrosshair</Hyperlink>
                        </TextBlock>
                        <TextBlock Margin="0,8,0,0">
                            <Run Text="Discord: "/>
                            <Hyperlink Foreground="{DynamicResource AccentBrush}" NavigateUri="https://discord.gg/AkuAZMwnGY" RequestNavigate="OnHyperlinkNavigate">https://discord.gg/AkuAZMwnGY</Hyperlink>
                        </TextBlock>
                        <TextBlock Text="License: MIT" Margin="0,8,0,0"/>
                        <Button x:Name="CheckUpdatesBtn" Content="Check for Updates" Width="180" Margin="0,12,0,0" Click="OnCheckUpdatesClick"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>

